# Copy this file to .env and fill in your values.
# Never commit .env — it contains real secrets.

# ── Database ──────────────────────────────────────────────────────────────────
# Used by the backend container to connect to Postgres.
# The default value matches the docker-compose.yml Postgres service config.
DATABASE_URL=postgresql://jobtracker:jobtracker@postgres:5432/jobtracker

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Set to "openai" or "anthropic"
LLM_PROVIDER=openai

# Required if LLM_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key_here

# Required if LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Create credentials at console.cloud.google.com → APIs & Services → Credentials
# Add http://localhost:5173 as an authorised JavaScript origin
GOOGLE_CLIENT_ID=your_google_client_id_here

# ── Auth (JWT) ────────────────────────────────────────────────────────────────
# Random secret used to sign JWTs. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-to-a-long-random-string
